{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "key": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": [
        "global",
        "candidate",
        "employer",
        "admin"
      ],
      "default": "global"
    },
    "description": {
      "type": "string"
    }
  },
  "required": [
    "key",
    "value"
  ]
}