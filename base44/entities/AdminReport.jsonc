{
  "name": "AdminReport",
  "type": "object",
  "properties": {
    "type": {
      "type": "string"
    },
    "target_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "reviewed",
        "resolved",
        "dismissed"
      ],
      "default": "pending"
    },
    "reviewed_by": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "type",
    "target_id"
  ]
}