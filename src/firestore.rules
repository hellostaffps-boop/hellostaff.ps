// ============================================================================
// Hello Staff — Firestore Security Rules Draft
// Phase 4.1 — Production Security Alignment
// ============================================================================
//
// PHILOSOPHY:
//   - Default deny unless explicitly allowed
//   - Require auth for all non-public reads
//   - Ownership checks via auth.uid comparison
//   - Organization membership verified through data model relationships
//   - platform_admin role sourced from Firestore users/{uid}.role (never from client)
//   - Sensitive field mutations blocked at rules level (role, status, verified, etc.)
//   - Narrow field-level write restrictions applied where Firestore rules support it
//
// IMPORTANT: These rules must be deployed via Firebase Console or Firebase CLI.
//   firebase deploy --only firestore:rules
//
// STATUS: Draft — reviewed against app data model. Deploy after QA.
// ============================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Global helper functions ──────────────────────────────────────────────

    // Is the caller authenticated?
    function isAuth() {
      return request.auth != null;
    }

    // Does the caller own the document by uid key?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Read the caller's user document role field from Firestore (never trust client)
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Is the caller a platform admin?
    function isAdmin() {
      return isAuth() && callerRole() == 'platform_admin';
    }

    // Is the caller an employer (owner or manager)?
    function isEmployer() {
      return isAuth() && callerRole() in ['employer_owner', 'employer_manager'];
    }

    // Is the caller a candidate?
    function isCandidate() {
      return isAuth() && callerRole() == 'candidate';
    }

    // Does the caller have an active membership in the given organization?
    function isMemberOf(orgId) {
      return isAuth() && exists(
        /databases/$(database)/documents/organization_members/$(request.auth.uid + '_member')
      ) && get(
        /databases/$(database)/documents/organization_members/$(request.auth.uid + '_member')
      ).data.organization_id == orgId
        && get(
        /databases/$(database)/documents/organization_members/$(request.auth.uid + '_member')
      ).data.status == 'active';
    }

    // Is the caller the owner of the given organization?
    function isOrgOwner(orgId) {
      return isAuth() && get(
        /databases/$(database)/documents/organizations/$(orgId)
      ).data.owner_user_id == request.auth.uid;
    }

    // ─── users ────────────────────────────────────────────────────────────────
    // Rule: users can read own doc; update only safe self-owned fields.
    // role, status, verified, admin_notes must NOT be writable by self.

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // Self-update: only safe fields allowed
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'status', 'is_admin', 'admin_notes', 'uid', 'created_at']);

      // Create: only during signup flow (uid must match auth uid)
      allow create: if isOwner(uid)
        && request.resource.data.role in ['candidate', 'employer_owner']
        && request.resource.data.uid == request.auth.uid;

      // Admin can read/update all user docs (for moderation, not role promotion)
      // Role promotion must happen via Admin SDK / Cloud Functions only
      allow write: if isAdmin();
    }

    // ─── candidate_profiles ───────────────────────────────────────────────────
    // Rule: candidates own their profile at candidate_profiles/{uid}.
    // No cross-user read/write. Employer access is intentionally restricted
    // until a controlled, rules-safe employer-facing candidate view is built.

    match /candidate_profiles/{uid} {
      allow read, write: if isOwner(uid);
      // Admin can read for moderation
      allow read: if isAdmin();
      // Employer read: currently restricted — to be unlocked when a safe
      // employer-facing candidate view is implemented with proper access tokens
    }

    // ─── employer_profiles ────────────────────────────────────────────────────
    // Rule: only the employer themselves can read/write their profile.
    // Org membership does not grant access to another employer's profile.

    match /employer_profiles/{uid} {
      allow read, write: if isOwner(uid);
      allow read: if isAdmin();
    }

    // ─── organizations ────────────────────────────────────────────────────────
    // Rule: owners can create and update their org.
    // Sensitive fields (verified, status, owner_user_id) must not be client-writable.
    // Org members can read the org but not update sensitive fields.

    match /organizations/{orgId} {
      // Any employer member may read their own org
      allow read: if isAuth() && (isOrgOwner(orgId) || isMemberOf(orgId) || isAdmin());

      // Owner can create their org (owner_user_id must equal their uid)
      allow create: if isAuth()
        && request.resource.data.owner_user_id == request.auth.uid;

      // Owner can update safe fields — must not change ownership or verification
      allow update: if isOrgOwner(orgId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['owner_user_id', 'verified', 'verified_at', 'verified_by', 'status']);

      // Admin can read/update all org data
      allow write: if isAdmin();
    }

    // ─── organization_members ────────────────────────────────────────────────
    // Rule: users must NOT arbitrarily add themselves as org members.
    // Owner membership is created during onboarding flow.
    // Adding/removing members is a privileged action → Cloud Functions later.

    match /organization_members/{memberId} {
      // Owner of the related org can read membership records
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isAdmin()
      );

      // Allow owner to create their own owner membership at signup time only
      allow create: if isAuth()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.role == 'owner';

      // Updates must be admin-only (manager assignment is privileged)
      allow update, delete: if isAdmin();
    }

    // ─── jobs ─────────────────────────────────────────────────────────────────
    // Rule: public can read published jobs.
    // Employers can create/update only for their own organization.
    // Candidates cannot create or modify jobs.

    match /jobs/{jobId} {
      // Public: only published jobs are readable by anyone
      allow read: if resource.data.status == 'published'
        || (isAuth() && (isOrgOwner(resource.data.organization_id) || isMemberOf(resource.data.organization_id)))
        || isAdmin();

      // Employer owner can create job for their org only
      allow create: if isAuth()
        && callerRole() in ['employer_owner', 'employer_manager']
        && request.resource.data.organization_id != null
        && isOrgOwner(request.resource.data.organization_id)
        && request.resource.data.created_by == request.auth.uid
        && request.resource.data.status in ['draft', 'published'];

      // Employer owner can update jobs they own
      allow update: if isAuth()
        && isOrgOwner(resource.data.organization_id)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['organization_id', 'created_by', 'created_at']);

      allow delete: if isOrgOwner(resource.data.organization_id) || isAdmin();
      allow write: if isAdmin();
    }

    // ─── applications ─────────────────────────────────────────────────────────
    // Rule: candidates can create/read only their own applications.
    // Employers can read applications only for their organization's jobs.
    // Employer updates are status-only for owned org.
    // Candidates cannot update applications once submitted (no withdraw client-side yet).

    match /applications/{appId} {
      // Candidate reads own application
      allow read: if isAuth() && resource.data.candidate_user_id == request.auth.uid;

      // Employer reads applications for their org
      allow read: if isAuth()
        && isOrgOwner(resource.data.organization_id);

      // Admin reads all
      allow read: if isAdmin();

      // Candidate creates own application — candidate_user_id must be their uid
      allow create: if isCandidate()
        && request.resource.data.candidate_user_id == request.auth.uid
        && request.resource.data.status == 'submitted';

      // Employer updates status only (not candidate_user_id, job_id, organization_id)
      allow update: if isAuth()
        && isOrgOwner(resource.data.organization_id)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updated_at', 'notes']);

      allow write: if isAdmin();
    }

    // ─── notifications ────────────────────────────────────────────────────────
    // Rule: users read/update only their own notifications.

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.user_id == request.auth.uid;

      // Only allowed mutation is marking as read
      allow update: if isAuth()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read', 'updated_at']);

      // Notifications are created by the backend (Cloud Functions) only
      allow create: if isAdmin(); // or Cloud Functions service account

      allow write: if isAdmin();
    }

    // ─── admin_reports ────────────────────────────────────────────────────────
    // Rule: normal users may create a report (limited).
    // Reading/updating reports is admin-only.

    match /admin_reports/{reportId} {
      allow create: if isAuth()
        && request.resource.data.reported_by == request.auth.uid;

      allow read, update, delete: if isAdmin();
    }

    // ─── settings ────────────────────────────────────────────────────────────
    // Rule: user-scoped settings are self-owned.
    // Platform/global settings are admin-only.

    match /settings/{settingId} {
      // User-scoped settings (scope == 'user' and owner == auth.uid)
      allow read, write: if isAuth()
        && resource.data.scope == 'user'
        && resource.data.owner_uid == request.auth.uid;

      // Global/platform settings
      allow read, write: if isAdmin();
    }

  }
}